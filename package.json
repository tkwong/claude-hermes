{
  "name": "claude-hermes",
  "version": "1.0.2",
  "type": "module",
  "bin": {
    "claude-hermes": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "telegram": "bun run src/index.ts telegram",
    "discord": "bun run src/index.ts discord",
    "status": "bun run src/index.ts status",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bun x @biomejs/biome check src tests scripts",
    "fmt": "bun x @biomejs/biome format --write src tests scripts",
    "test": "bun test src",
    "test:smoke": "bun test tests/smoke",
    "test:integration": "bun test tests/integration",
    "verify": "bun run scripts/verify.ts",
    "verify:fast": "bun run scripts/verify.ts --fast",
    "release": "bun run scripts/release.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.9",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ogg-opus-decoder": "^1.7.3"
  }
}
